@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix st:    <https://socialcaredata.github.io/ontology/placements/vocab/support-type#> .

<https://socialcaredata.github.io/ontology/placements/vocab/support-type> a owl:Ontology , skos:ConceptScheme ;
    dct:title "Support Type Vocabulary" ;
    rdfs:label "Support Type" ;
    skos:prefLabel "Support Type" ;
    dct:description "Controlled vocabulary for additional support provision required alongside a placement. Multi-valued: select all that apply." ;
    owl:versionInfo "1.0.0" ;
    skos:hasTopConcept st:AdditionalSupervision , st:TherapeuticSupport , st:WorkerForRespite , st:TaxisToSchool , st:NotApplicable , st:Other .

st:SupportRequirement a owl:Class ;
    rdfs:label "Support Requirement Instance" ;
    skos:prefLabel "Support Requirement Instance" ;
    skos:definition "Support type wrapper to encapsulate support_type (Other) - value pairs." .

st:supportType a owl:ObjectProperty ;
    rdfs:domain st:SupportRequirement ;
    rdfs:range skos:Concept .

st:AdditionalSupervision a skos:Concept ;
    skos:inScheme <https://socialcaredata.github.io/ontology/placements/vocab/support-type> ;
    skos:topConceptOf <https://socialcaredata.github.io/ontology/placements/vocab/support-type> ;
    skos:prefLabel "Additional supervision" ;
    skos:notation "additional-supervision" ;
    skos:definition "Additional supervision is required." .

st:TherapeuticSupport a skos:Concept ;
    skos:inScheme <https://socialcaredata.github.io/ontology/placements/vocab/support-type> ;
    skos:topConceptOf <https://socialcaredata.github.io/ontology/placements/vocab/support-type> ;
    skos:prefLabel "Therapeutic support" ;
    skos:notation "therapeutic-support" ;
    skos:definition "Therapeutic support is required." .

st:WorkerForRespite a skos:Concept ;
    skos:inScheme <https://socialcaredata.github.io/ontology/placements/vocab/support-type> ;
    skos:topConceptOf <https://socialcaredata.github.io/ontology/placements/vocab/support-type> ;
    skos:prefLabel "A worker for respite" ;
    skos:notation "worker-respite" ;
    skos:definition "A worker is required to provide respite." .

st:TaxisToSchool a skos:Concept ;
    skos:inScheme <https://socialcaredata.github.io/ontology/placements/vocab/support-type> ;
    skos:topConceptOf <https://socialcaredata.github.io/ontology/placements/vocab/support-type> ;
    skos:prefLabel "Taxis to school" ;
    skos:notation "taxis-to-school" ;
    skos:definition "Taxis to and from school are required." .

st:NotApplicable a skos:Concept ;
    skos:inScheme <https://socialcaredata.github.io/ontology/placements/vocab/support-type> ;
    skos:topConceptOf <https://socialcaredata.github.io/ontology/placements/vocab/support-type> ;
    skos:prefLabel "Not applicable" ;
    skos:altLabel "NA" ;
    skos:notation "na" ;
    skos:definition "No additional support is required." .

st:Other a skos:Concept ;
    skos:inScheme <https://socialcaredata.github.io/ontology/placements/vocab/support-type> ;
    skos:topConceptOf <https://socialcaredata.github.io/ontology/placements/vocab/support-type> ;
    skos:prefLabel "Other" ;
    skos:notation "other" ;
    skos:definition "Other additional support is required, specified in free text as rdf:value." .
