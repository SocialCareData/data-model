@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix cln:   <https://socialcaredata.github.io/ontology/placements/vocab/cultural-need#> .

<https://socialcaredata.github.io/ontology/placements/vocab/cultural-need> a owl:Ontology , skos:ConceptScheme ;
    dct:title "Cultural Need Vocabulary" ;
    rdfs:label "Cultural Need" ;
    skos:prefLabel "Cultural Need" ;
    dct:description "Controlled vocabulary indicating whether a child has specific cultural needs that the placement home must accommodate (e.g., places of worship, religious activities)." ;
    owl:versionInfo "1.0.0" ;
    skos:hasTopConcept cln:Required , cln:NotRequired , cln:NotKnown , cln:Other .

cln:CulturalRequirement rdf:type owl:Class ;
                            rdfs:label "Cultural Requirement Instance" ;
                            skos:definition "Cultural requirement type wrapper to encapsulate cultural_req_type (Other) - value pairs." ;
                            skos:prefLabel "Cultural Requirement Instance" .

cln:culturalNeed rdf:type owl:ObjectProperty ;
                     rdfs:domain cln:CulturalRequirement ;
                     rdfs:range skos:Concept .

cln:Required a skos:Concept ;
    skos:inScheme <https://socialcaredata.github.io/ontology/placements/vocab/cultural-need> ;
    skos:topConceptOf <https://socialcaredata.github.io/ontology/placements/vocab/cultural-need> ;
    skos:prefLabel "Required" ;
    skos:notation "required" ;
    skos:definition "Specific cultural accommodations are required." .

cln:NotRequired a skos:Concept ;
    skos:inScheme <https://socialcaredata.github.io/ontology/placements/vocab/cultural-need> ;
    skos:topConceptOf <https://socialcaredata.github.io/ontology/placements/vocab/cultural-need> ;
    skos:prefLabel "Not required" ;
    skos:notation "not-required" ;
    skos:definition "No specific cultural accommodations are required." .

cln:NotKnown a skos:Concept ;
    skos:inScheme <https://socialcaredata.github.io/ontology/placements/vocab/cultural-need> ;
    skos:topConceptOf <https://socialcaredata.github.io/ontology/placements/vocab/cultural-need> ;
    skos:prefLabel "Not known" ;
    skos:notation "not-known" ;
    skos:definition "Whether cultural accommodations are required is not known." .

cln:Other a skos:Concept ;
    skos:inScheme <https://socialcaredata.github.io/ontology/placements/vocab/cultural-need> ;
    skos:topConceptOf <https://socialcaredata.github.io/ontology/placements/vocab/cultural-need> ;
    skos:prefLabel "Other" ;
    skos:notation "other" ;
    skos:definition "Other cultural needs apply, captured in free text. Use rdf:value to provide details." .
