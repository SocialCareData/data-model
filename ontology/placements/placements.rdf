<?xml version="1.0"?>
<rdf:RDF xmlns="https://socialcaredata.github.io/ontology/placements#"
     xml:base="https://socialcaredata.github.io/ontology/placements"
     xmlns:cn="https://socialcaredata.github.io/ontology/placements/vocab/communication-need#"
     xmlns:la="https://socialcaredata.github.io/ontology/placements/vocab/living-arrangement#"
     xmlns:pa="https://socialcaredata.github.io/ontology/placements/vocab/pets-allowance#"
     xmlns:pl="https://socialcaredata.github.io/ontology/placements#"
     xmlns:pt="https://socialcaredata.github.io/ontology/placements/vocab/placement-type#"
     xmlns:pu="https://socialcaredata.github.io/ontology/placements/vocab/placement-urgency#"
     xmlns:rl="https://socialcaredata.github.io/ontology/placements/vocab/risk-level#"
     xmlns:sl="https://socialcaredata.github.io/ontology/placements/vocab/suitability-level#"
     xmlns:st="https://socialcaredata.github.io/ontology/placements/vocab/support-type#"
     xmlns:cln="https://socialcaredata.github.io/ontology/placements/vocab/cultural-need#"
     xmlns:dct="http://purl.org/dc/terms/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:yns="https://socialcaredata.github.io/ontology/placements/vocab/presence-status#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/">
    <owl:Ontology rdf:about="https://socialcaredata.github.io/ontology/placements">
        <owl:imports rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/communication-need"/>
        <owl:imports rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/cultural-need"/>
        <owl:imports rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/living-arrangement"/>
        <owl:imports rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/pets-allowance"/>
        <owl:imports rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/placement-type"/>
        <owl:imports rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/placement-urgency"/>
        <owl:imports rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/risk-level"/>
        <owl:imports rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/suitability-level"/>
        <owl:imports rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/support-type"/>
        <owl:imports rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/presence-status"/>
        <dct:creator>ODI / SocialCareData working group</dct:creator>
        <dct:description xml:lang="en">An OWL ontology that models the data captured by a local authority when arranging a placement for a looked-after child.</dct:description>
        <dct:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-27</dct:issued>
        <dct:source rdf:resource="https://socialcaredata.github.io/spec/placements/"/>
        <dct:title xml:lang="en">Children&apos;s Social Care Placements Ontology</dct:title>
        <vann:preferredNamespacePrefix>sc</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://socialcaredata.github.io/ontology/placements#</vann:preferredNamespaceUri>
        <rdfs:label xml:lang="en">Placements Ontology</rdfs:label>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/issued -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/issued"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>
    


    <!-- https://socialcaredata.github.io/ontology/placements#additionalSupport -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#additionalSupport">
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRequirements"/>
        <rdfs:range rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/support-type#SupportRequirement"/>
        <rdfs:comment xml:lang="en">Additional support provision required (e.g., additional supervision, therapeutic support, taxis to school). Multi-valued.</rdfs:comment>
        <rdfs:label xml:lang="en">additional support</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/support-type"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#communicationNeeds -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#communicationNeeds">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRequirements"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether the child has any communication, language or learning needs.</rdfs:comment>
        <rdfs:label xml:lang="en">communication needs</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/presence-status"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#culturalNeeds -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#culturalNeeds">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRequirements"/>
        <rdfs:range rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/cultural-need#CulturalRequirement"/>
        <rdfs:comment xml:lang="en">Whether the placement must accommodate specific cultural needs (e.g., access to places of worship).</rdfs:comment>
        <rdfs:label xml:lang="en">cultural needs</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/cultural-need"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#fosterCareSuitability -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#fosterCareSuitability">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRecommendation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Suitability of foster care for this child, as judged by the social worker.</rdfs:comment>
        <rdfs:label xml:lang="en">foster care suitability</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/suitability-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#hasActualPlacement -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#hasActualPlacement">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#Placement"/>
        <rdfs:range rdf:resource="https://socialcaredata.github.io/ontology/placements#ActualPlacement"/>
        <rdfs:comment xml:lang="en">Links a Placement to the ActualPlacement that was arranged. Optional - a referral may exist without (yet) having an actual placement.</rdfs:comment>
        <rdfs:label xml:lang="en">has actual placement</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#hasPlacementAvailability -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#hasPlacementAvailability">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#Placement"/>
        <rdfs:range rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementAvailability"/>
        <rdfs:label>has placement availability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#hasPlacementRecommendation -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#hasPlacementRecommendation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#Placement"/>
        <rdfs:range rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRecommendation"/>
        <rdfs:comment xml:lang="en">Links a Placement to its PlacementRecommendation.</rdfs:comment>
        <rdfs:label xml:lang="en">has placement recommendation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#hasPlacementRequirements -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#hasPlacementRequirements">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#Placement"/>
        <rdfs:range rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRequirements"/>
        <rdfs:comment xml:lang="en">Links a Placement to its PlacementRequirements.</rdfs:comment>
        <rdfs:label xml:lang="en">has placement requirements</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#hasQualityAssurance -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#hasQualityAssurance">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#Placement"/>
        <rdfs:range rdf:resource="https://socialcaredata.github.io/ontology/placements#QualityAssurance"/>
        <rdfs:comment xml:lang="en">Links a Placement to its QualityAssurance metadata.</rdfs:comment>
        <rdfs:label xml:lang="en">has quality assurance</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#hasRiskAssessment -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#hasRiskAssessment">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#Placement"/>
        <rdfs:range rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:comment xml:lang="en">Links a Placement to its RiskAssessment.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk assessment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#livingCompanions -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#livingCompanions">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRequirements"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Recommendation as to who the child can be cared for alongside (e.g., solo placement, with other children, only older children).</rdfs:comment>
        <rdfs:label xml:lang="en">living companions</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/living-arrangement"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#neededBy -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#neededBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementAvailability"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">When the child needs to be placed by. Captures urgency rather than an absolute date, as deep-dive participants felt &apos;date placement required by&apos; was too subjective.</rdfs:comment>
        <rdfs:label xml:lang="en">needed by</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/placement-urgency"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#pets -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#pets">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRequirements"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether the child can or must live in a home with pets/animals.</rdfs:comment>
        <rdfs:label xml:lang="en">pets allowance</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/pets-allowance"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#placementType -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#placementType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#ActualPlacement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">The type of placement the child received.</rdfs:comment>
        <rdfs:label xml:lang="en">placement type</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/placement-type"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#residentialCareSuitability -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#residentialCareSuitability">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRecommendation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Suitability of residential care for this child.</rdfs:comment>
        <rdfs:label xml:lang="en">residential care suitability</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/suitability-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskCriminalExploitation -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskCriminalExploitation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether the child is known to be at risk of criminal exploitation.</rdfs:comment>
        <rdfs:label xml:lang="en">risk: criminal exploitation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/risk-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskDrugAlcohol -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskDrugAlcohol">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether the child is known to be at risk of drug and alcohol use.</rdfs:comment>
        <rdfs:label xml:lang="en">risk: drug and alcohol use</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/risk-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskEatingDisorder -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskEatingDisorder">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether the child is known to be at risk of an eating disorder.</rdfs:comment>
        <rdfs:label xml:lang="en">risk: eating disorder</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/risk-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskMissing -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskMissing">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether the child is known to be at risk of going missing.</rdfs:comment>
        <rdfs:label xml:lang="en">risk: going missing</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/risk-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskSelfHarm -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskSelfHarm">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether the child is known to be at risk of self-harm.</rdfs:comment>
        <rdfs:label xml:lang="en">risk: self-harm</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/risk-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskSexualExploitation -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskSexualExploitation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether the child is known to be at risk of sexual exploitation.</rdfs:comment>
        <rdfs:label xml:lang="en">risk: sexual exploitation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/risk-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskToOthersAnimals -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskToOthersAnimals">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether there is a known risk of harm to animals.</rdfs:comment>
        <rdfs:label xml:lang="en">risk to others: harm to animals</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/risk-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskToOthersCriminal -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskToOthersCriminal">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether there is a known risk of criminal exploitation for others in the home.</rdfs:comment>
        <rdfs:label xml:lang="en">risk to others: criminal exploitation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/risk-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskToOthersFire -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskToOthersFire">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether there is a known risk of fire-setting.</rdfs:comment>
        <rdfs:label xml:lang="en">risk to others: fire-setting</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/risk-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskToOthersPhysical -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskToOthersPhysical">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether there is a known risk of physical harm to others.</rdfs:comment>
        <rdfs:label xml:lang="en">risk to others: physical harm</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/risk-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskToOthersSexual -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskToOthersSexual">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Whether there is a known risk of sexual harm to others.</rdfs:comment>
        <rdfs:label xml:lang="en">risk to others: sexual harm</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/risk-level"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#specificCommunicationRequirement -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#specificCommunicationRequirement">
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRequirements"/>
        <rdfs:range rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/communication-need#CommunicationRequirement"/>
        <rdfs:comment xml:lang="en">Specific communication or language requirement (ESOL, BSL, Makaton, Other, None). Multi-valued: a placement may have several.</rdfs:comment>
        <rdfs:label xml:lang="en">specific communication requirement</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/communication-need"/>
    </owl:ObjectProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#supportedAccommodationSuitability -->

    <owl:ObjectProperty rdf:about="https://socialcaredata.github.io/ontology/placements#supportedAccommodationSuitability">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRecommendation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Suitability of supported accommodation for this child.</rdfs:comment>
        <rdfs:label xml:lang="en">supported accommodation suitability</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/suitability-level"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://socialcaredata.github.io/ontology/placements#additionalSupportOther -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#additionalSupportOther">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRequirements"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Free-text description of any additional support not captured by the standard SupportType options. Used when the &apos;Other&apos; SupportType concept is selected.</rdfs:comment>
        <rdfs:label xml:lang="en">additional support: other (free text)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#childId -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#childId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#Placement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifier unique to each child within the LA, allowing linking between multiple referrals for the same child.</rdfs:comment>
        <rdfs:label xml:lang="en">child ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#costDate -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#costDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#QualityAssurance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date the placement cost data was captured.</rdfs:comment>
        <rdfs:label xml:lang="en">cost date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#costOfficerName -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#costOfficerName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#QualityAssurance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the officer who recorded the placement cost data.</rdfs:comment>
        <rdfs:label xml:lang="en">cost officer name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#deprivationOfLiberty -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#deprivationOfLiberty">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRequirements"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Whether the child has a Deprivation of Liberty Order (DOL).</rdfs:comment>
        <rdfs:label xml:lang="en">deprivation of liberty order</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#homeAdaptationRequired -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#homeAdaptationRequired">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementRequirements"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Whether adaptations to the home are required to accommodate the child&apos;s needs.</rdfs:comment>
        <rdfs:label xml:lang="en">home adaptation required</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#isEducationContinuous -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#isEducationContinuous">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#ActualPlacement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Whether the child&apos;s education was continuous (i.e., not disrupted) as a result of this placement. In some cases an education disruption may be in line with the care plan.</rdfs:comment>
        <rdfs:label xml:lang="en">is education continuous</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#isLocationPreferred -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#isLocationPreferred">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#ActualPlacement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Whether the actual placement location was a preferred location.</rdfs:comment>
        <rdfs:label xml:lang="en">is location preferred</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#placementDate -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#placementDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#QualityAssurance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date the actual placement data was captured.</rdfs:comment>
        <rdfs:label xml:lang="en">placement date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#placementId -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#placementId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementAvailability"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The unique identifier of the placement record within the LA case management system.</rdfs:comment>
        <rdfs:label xml:lang="en">placement ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#placementLocation -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#placementLocation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#ActualPlacement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">First 3-4 digits of the postcode for the actual placement location. Captured in addition to the provider URN to ensure location is recorded for non-registered placements.</rdfs:comment>
        <rdfs:label xml:lang="en">placement location</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#placementOfficerName -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#placementOfficerName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#QualityAssurance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the officer who recorded the actual placement information.</rdfs:comment>
        <rdfs:label xml:lang="en">placement officer name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#preferredLocation -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#preferredLocation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementAvailability"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Preferred area for the placement search. Free text in the current spec; an authoritative geographic vocabulary is still being explored.</rdfs:comment>
        <rdfs:label xml:lang="en">preferred location</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#providerURN -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#providerURN">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#ActualPlacement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Provider Unique Reference Number, linked to Ofsted registration. Allows the placement to be linked to Ofsted data about the provider.</rdfs:comment>
        <rdfs:label xml:lang="en">provider URN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#referralDate -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#referralDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#QualityAssurance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date the referral data was captured.</rdfs:comment>
        <rdfs:label xml:lang="en">referral date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#referralOfficerName -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#referralOfficerName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#QualityAssurance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the officer who recorded the referral information. Used for LA-internal QA only.</rdfs:comment>
        <rdfs:label xml:lang="en">referral officer name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskOther -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskOther">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Free-text description of any other risks the child is exposed to that are not captured by the standard risk fields.</rdfs:comment>
        <rdfs:label xml:lang="en">risk: other (free text)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#riskToOthersOther -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#riskToOthersOther">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Free-text description of any other risks to others or property that are not captured by the standard risk-to-others fields.</rdfs:comment>
        <rdfs:label xml:lang="en">risk to others: other (free text)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#siblingCount -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#siblingCount">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#PlacementAvailability"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en">How many siblings the child should ideally be placed with according to the care plan. 0 if the child has no siblings or is not to be placed with siblings.</rdfs:comment>
        <rdfs:label xml:lang="en">sibling count</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#siblingsPlacedTogether -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#siblingsPlacedTogether">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#ActualPlacement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en">How many siblings were actually placed together. Allows comparison with the intended sibling count from the referral.</rdfs:comment>
        <rdfs:label xml:lang="en">siblings placed together</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://socialcaredata.github.io/ontology/placements#totalWeeklyCost -->

    <owl:DatatypeProperty rdf:about="https://socialcaredata.github.io/ontology/placements#totalWeeklyCost">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://socialcaredata.github.io/ontology/placements#ActualPlacement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Total weekly fee paid for the placement, excluding VAT. Captures the actual fee paid rather than the fee agreed at the point of IPA, as discussed in deep-dive sessions.</rdfs:comment>
        <rdfs:label xml:lang="en">total weekly cost</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://socialcaredata.github.io/ontology/placements#ActualPlacement -->

    <owl:Class rdf:about="https://socialcaredata.github.io/ontology/placements#ActualPlacement">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://socialcaredata.github.io/ontology/placements#placementType"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/placement-type"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Describes the placement actually arranged for the child, including weekly cost, location, provider URN, sibling co-placement and educational continuity. Optional - a Placement may not (yet) have an ActualPlacement.</rdfs:comment>
        <rdfs:label xml:lang="en">Actual Placement</rdfs:label>
    </owl:Class>
    


    <!-- https://socialcaredata.github.io/ontology/placements#Placement -->

    <owl:Class rdf:about="https://socialcaredata.github.io/ontology/placements#Placement">
        <rdfs:label>Placement</rdfs:label>
    </owl:Class>
    


    <!-- https://socialcaredata.github.io/ontology/placements#PlacementAvailability -->

    <owl:Class rdf:about="https://socialcaredata.github.io/ontology/placements#PlacementAvailability">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://socialcaredata.github.io/ontology/placements#neededBy"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/placement-urgency"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A placement record covering the full lifecycle of a placement instance: the referral request (urgency, sibling count, preferred location), the social-worker recommendation, the placement requirements (needs), the risk assessment, the actual placement found (if any), and quality-assurance metadata. Equivalent to the central &apos;PlacementAvailability&apos; table in the data model diagram.</rdfs:comment>
        <rdfs:label xml:lang="en">Placement Availability</rdfs:label>
        <skos:altLabel xml:lang="en">Placement Availability</skos:altLabel>
        <skos:altLabel xml:lang="en">Placement Referral</skos:altLabel>
    </owl:Class>
    


    <!-- https://socialcaredata.github.io/ontology/placements#PlacementRecommendation -->

    <owl:Class rdf:about="https://socialcaredata.github.io/ontology/placements#PlacementRecommendation">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://socialcaredata.github.io/ontology/placements#fosterCareSuitability"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/suitability-level"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://socialcaredata.github.io/ontology/placements#residentialCareSuitability"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/suitability-level"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://socialcaredata.github.io/ontology/placements#supportedAccommodationSuitability"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/suitability-level"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The social worker&apos;s recommendation of which categories of placement (foster, residential, supported accommodation) are preferred, suitable but not preferred, unsuitable, or unspecified.</rdfs:comment>
        <rdfs:label xml:lang="en">Placement Recommendation</rdfs:label>
    </owl:Class>
    


    <!-- https://socialcaredata.github.io/ontology/placements#PlacementRequirements -->

    <owl:Class rdf:about="https://socialcaredata.github.io/ontology/placements#PlacementRequirements">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://socialcaredata.github.io/ontology/placements#additionalSupport"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/support-type"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://socialcaredata.github.io/ontology/placements#communicationNeeds"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/presence-status"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://socialcaredata.github.io/ontology/placements#culturalNeeds"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="https://socialcaredata.github.io/ontology/placements/vocab/cultural-need"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://socialcaredata.github.io/ontology/placements#livingCompanions"/>
                <owl:allValuesFrom>
